# ── Banco de Dados ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=consultorprocessos_dev
DB_USER=dev
DB_PASSWORD=dev
FLYWAY_USER=dev
FLYWAY_PASSWORD=dev

# ── Redis ──────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── RabbitMQ ───────────────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=dev
RABBITMQ_PASSWORD=dev

# ── Crawler Workers ────────────────────────────────────────────
CRAWLER_WORKERS_MIN=3
CRAWLER_WORKERS_MAX=10

# ── Aplicação ──────────────────────────────────────────────────
APP_BASE_URL=http://localhost:4200
ADMIN_EMAIL=admin@consultorprocessos.com.br
APP_VERSION=0.0.1-SNAPSHOT

# ── JWT (RS256) ────────────────────────────────────────────────
# Gerar conforme instruções em application-prod.yml
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# ── E-mail (SMTP) ──────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=
EMAIL_SENDER_ADDRESS=noreply@consultorprocessos.com.br
EMAIL_SENDER_NAME=Consultor de Processos
